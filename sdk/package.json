{
  "name": "@tickpay/sdk",
  "version": "0.1.0",
  "description": "TickPay SDK core primitives for EIP-7702 streaming payments",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./core/abis": {
      "import": "./src/core/abis.js",
      "types": "./src/core/abis.d.ts"
    },
    "./core/eip712": {
      "import": "./src/core/eip712.js",
      "types": "./src/core/eip712.d.ts"
    },
    "./core/types": {
      "import": "./src/core/types.js",
      "types": "./src/core/types.d.ts"
    },
    "./adapters/monad": {
      "import": "./src/adapters/monad.js",
      "types": "./src/adapters/monad.d.ts"
    },
    "./client/relayerHttp": {
      "import": "./src/client/relayerHttp.js",
      "types": "./src/client/relayerHttp.d.ts"
    },
    "./server/sessionEngine": {
      "import": "./src/server/sessionEngine.js",
      "types": "./src/server/sessionEngine.d.ts"
    },
    "./server/eip7702": {
      "import": "./src/server/eip7702.js",
      "types": "./src/server/eip7702.d.ts"
    },
    "./server/sessionStore": {
      "import": "./src/server/sessionStore.js",
      "types": "./src/server/sessionStore.d.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test ./test/*.test.mjs"
  },
  "dependencies": {
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
