{
  "name": "tickpay-web",
  "version": "1.0.0",
  "description": "TickPay Web - Video billing frontend with EIP-7702",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "wrangler pages deploy .vercel/output/static --project-name=tickpay",
    "pages:dev": "wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat"
  },
  "dependencies": {
    "@tickpay/sdk": "workspace:*",
    "@privy-io/react-auth": "^3.12.0",
    "next": "^15.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "agentation": "^1.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.60.0"
  }
}
