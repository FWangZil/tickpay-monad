# TickPay Web Environment Variables
# Copy this file to .env.local and fill in the deployed contract addresses

# Relayer service URL (default: http://localhost:3001)
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001

# Deployed VideoSessionLogic contract address
# Run: cd contracts && forge script script/DeployVideoSession.s.sol --broadcast -vvv
# The output will show the contract address
NEXT_PUBLIC_LOGIC_CONTRACT=0x...

# Deployed MockERC20 token address
# Same deployment script will output this
NEXT_PUBLIC_TOKEN=0x...

# Monad chain ID (default: 10143)
NEXT_PUBLIC_CHAIN_ID=10143

# Optional: Custom RPC URL (default: https://testnet-rpc.monad.xyz)
# NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
